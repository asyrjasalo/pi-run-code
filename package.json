{
  "name": "pi-run-code",
  "version": "0.1.0",
  "description": "Run JavaScript/TypeScript code within PI coding agent",
  "keywords": [
    "pi-package",
    "pi-extension",
    "code-mode"
  ],
  "license": "MIT",
  "homepage": "https://github.com/asyrjasalo/pi-run-code",
  "repository": {
    "type": "git",
    "url": "https://github.com/asyrjasalo/pi-run-code.git"
  },
  "type": "commonjs",
  "files": [
    "src/",
    "test/"
  ],
  "scripts": {
    "test": "node test/run.js",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "tsc": "tsc --noEmit"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "dependencies": {
    "esbuild": "^0.27.3",
    "secure-exec": "^0.2.1",
    "typescript": "^5.9.3",
    "zx": "^8.8.5"
  },
  "peerDependencies": {
    "@mariozechner/pi-agent-core": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  }
}
